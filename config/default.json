{
  "port": "env(PORT)",
  "settings": {
    "session": {
      "store": "@foal/typeorm"
    }
  },
  "database": {
    "type": "sqlite",
    "database": "./db.sqlite3"
  },
  "jwt": {
    "secret": "env(JWT_SECRET)",
    "accessTokenExpiresIn": "15m",
    "refreshTokenExpiresIn": "7d"
  },
  "bcrypt": {
    "saltRounds": 10
  },
  "app": {
    "baseUrl": "env(APP_BASE_URL)",
    "frontendBaseUrl": "env(APP_FRONTEND_BASE_URL)"
  }
}
