{
  "settings": {
    "logger": {
      "logHttpRequests": false
    }
  },
  "database": {
    "database": "env(DATABASE_NAME_E2E)",
    "dropSchema": true,
    "synchronize": true,
    "pool": {
      "max": 5,
      "min": 1,
      "idleTimeout": 10000,
      "connectionTimeout": 2000
    }
  }
}
